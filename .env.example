DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_URL="https://your-staging-url.vercel.app"
NEXTAUTH_SECRET="replace-with-long-random-secret"
SPORTSDATAIO_API_KEY="replace-with-sportsdataio-key"

# Optional: used only when running prisma/bootstrap-admin.ts
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_DISPLAY_NAME="Admin"
ADMIN_REAL_NAME="Admin User"
ADMIN_PHONE=""
ADMIN_WALLET_GRANT="1000"
