DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_URL="https://your-staging-url.vercel.app"
NEXTAUTH_SECRET="replace-with-long-random-secret"
SPORTSDATAIO_API_KEY="replace-with-sportsdataio-key"

# Password reset emails (Resend). Required in production; in development missing key logs the reset URL instead.
RESEND_API_KEY="re_..."
# Public site URL for links in emails (no trailing slash), e.g. https://app.fantasytrack.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: used only when running prisma/bootstrap-admin.ts
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_DISPLAY_NAME="Admin"
ADMIN_REAL_NAME="Admin User"
ADMIN_PHONE=""
ADMIN_WALLET_GRANT="1000"
